# 【1】 最初に全ファイル禁止
# すべてのファイルをignoreするがフォルダはしない
# gitは空フォルダは無視されるので影響はない
*
!*/

# 【2】 次に任意のファイルやフォルダを許可
# このファイルと同階層のフォルダ階層以降を許可
# !/lib/**
# このファイルと同階層以降の「??？_m」というフォルダ階層以降を許可
# !**/*_m/**
# このファイルと同階層のファイルだけ許可
!/.gitignore
!/.gitattributes
!*.ts
!*.html
!*.json
!*.css
!*.png
!*gif
!*.icns
!*.ico
!*.eslintrc
!*.md
!new_deploy.py
!*.cjs
!*.rs
!*.toml
!Cargo.lock
!.github/workflows/*.yml
!tools/stage_tauri.js


# 【3】 最後に常に除外するファイルやフォルダを禁止
# OSが自動で作るファイル
.DS_Store
Thumbs.db
node_modules/*
dist/*
build/*
assets/sprites/**
!assets/sprites/manifest.json
!assets/sprites/map-themes.json
# Audio assets: redistribution not permitted (see assets/bgm/README.md, assets/se/README.md).
# Keep out of version control; only the README stays committed as a license ledger.
assets/bgm/**
!assets/bgm/README.md
assets/se/**
!assets/se/README.md
CLAUDE.md

# Tauri build artifacts (Rust target/ + Tauri dev webview bridge log outside repo).
# Note: src-tauri/.gitignore exists on disk from the Tauri scaffold, but is
# itself ignored by the top `*` rule above (no whitelist entry for subtree
# .gitignore files). These blacklists here are therefore the sole effective
# rules — without them, .rs files under target/ would leak in via `!*.rs`.
src-tauri/target/**
src-tauri/gen/**
# Tauri frontend staging (generated by tools/stage_tauri.js)
tauri-dist/
# Legacy: junction under public/ from an earlier PoC iteration (now unused)
public/assets
